<?php $product = $this->getProduct(); ?>
<?php $categories = $this->getCategories(); ?>

<h2><?php echo $product->product_id ? 'Edit Product' : 'Add New Product'; ?></h2>

<form method="POST" action="<?php echo $this->getUrl('save'); ?>">
    <input type="hidden" name="product[product_id]" value="<?php echo $product->product_id; ?>">

    <table border="1" width="100%">
        <tr>
            <td>Name</td>
            <td><input type="text" name="product[name]" value="<?php echo $product->name; ?>"></td>
        </tr>
        <tr>
            <td>Quantity</td>
            <td><input type="text" name="product[quantity]" value="<?php echo $product->quantity; ?>"></td>
        </tr>
        <tr>
            <td>Price</td>
            <td><input type="text" name="product[price]" value="<?php echo $product->price; ?>"></td>
        </tr>
        <tr>
            <td>Description</td>
            <td><input type="text" name="product[description]" value="<?php echo $product->description; ?>"></td>
        </tr>
        <tr>
            <td>Status</td>
            <td>
                <select name="product[status]">
                    <?php foreach($product->getStatusOption() as $key => $value): ?>
                        <option value="<?php echo $key; ?>" <?php echo $product->status == $key ? 'selected' : ''; ?>><?php echo $value; ?></option>
                    <?php endforeach; ?>
                </select>
            </td>
        </tr>
        <tr>
            <td>Category</td>
            <td>
                <select name="product[category_id]">
                    <option value="">Select Category</option>
                    <?php foreach($categories as $category): ?>
                        <option value="<?php echo $category->category_id; ?>" <?php echo ($product->category_id == $category->category_id) ? 'selected' : ''; ?>><?php echo $category->name; ?></option>
                    <?php endforeach; ?>
                </select>
            </td>
        </tr>
       
        <tr>
            <td colspan="2">
                <button type="submit">Save</button>
                <a href="<?php echo $this->getUrl('list'); ?>">Back</a>
            </td>
        </tr>
    </table>
</form>