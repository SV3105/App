<?php $data = $this->getDataValue('admin'); ?>

<h2><?php echo $data->admin_id ? 'Edit Admin' : 'Add New Admin'; ?></h2>

<form method="POST" action="index.php?c=admin&a=save">
    <input type="hidden" name="admin[admin_id]" value="<?php echo $data->admin_id; ?>">

    <table border="1" width="100%">
        <tr>
            <td>Username</td>
            <td>
                <input type="text" name="admin[username]" value="<?php echo $data->username; ?>">
            </td>
        </tr>
        <tr>
            <td>Password</td>
            <td>
                <input type="text" name="admin[password]" value="<?php echo $data->password; ?>">
            </td>
        </tr>
        <tr>
            <td>Email</td>
            <td>
                <input type="text" name="admin[email]" value="<?php echo $data->email; ?>">
            </td>
        </tr>
        <tr>
            <td>Status</td>
            <td>
                <select name="admin[status]">
                    <?php foreach($data->getStatusOption() as $key => $value): ?>
                        <option value="<?php echo $key; ?>" <?php echo $data->status == $key ? 'selected' : ''; ?>><?php echo $value; ?></option>
                    <?php endforeach; ?>
                </select>
            </td>
        </tr>
        <tr>
            <td colspan="2">
                <button type="submit">Save</button>
                <a href="index.php?c=admin&a=list">Back</a>
            </td>
        </tr>
    </table>
</form>
