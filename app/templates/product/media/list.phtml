                <td><?php echo $row->updated_date; ?></td>
                <td>
                    <a href="index.php?c=product_media&a=edit&id=<?php echo $row->product_media_id; ?>">Edit</a> |
                    <a href="index.php?c=product_media&a=delete&id=<?php echo $row->product_media_id; ?>">Delete</a>
                </td>
            </tr>
