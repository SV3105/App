
<h2>Customer List</h2>
<a href="<?php echo $this->getUrl('edit', 'customer'); ?>">Add New Customer</a>
<br><br>

<table border="1" width="100%">
    <tr>
        <th>ID</th>
        <th>First Name</th>
        <th>Last Name</th>
        <th>Email</th>
        <th>Group Name</th>
        <th>Status</th>
        <th>Created Date</th>
        <th>Updated Date</th>
        <th>Actions</th>
    </tr>
    <?php if (!empty($this->getData())): ?>
        <?php foreach ($this->getData() as $customer): ?>
            <tr>
                <td><?php echo $customer->customer_id; ?></td>
                <td><?php echo $customer->first_name; ?></td>
                <td><?php echo $customer->last_name; ?></td>
                <td><?php echo $customer->email; ?></td>
                <td><?php echo $customer->group_name; ?></td>
                <td><?php echo $customer->getStatus(); ?></td>
                <td><?php echo $customer->created_date; ?></td>
                <td><?php echo $customer->updated_date; ?></td>
                <td>
                    <a href="<?php echo $this->getUrl('edit', 'customer', ['id' => $customer->customer_id]); ?>">Edit</a> |
                    <a href="<?php echo $this->getUrl('delete', 'customer', ['id' => $customer->customer_id]); ?>">Delete</a>
                </td>
            </tr>
        <?php endforeach; ?>
    <?php else: ?>
        <tr>
            <td colspan="9">No records found.</td>
        </tr>
    <?php endif; ?>
</table>